class LRUCache {

    Map<Integer,Integer> cacheImpl; 
    int capacity;
    public LRUCache(int capacity) {
        cacheImpl=new LinkedHashMap<>(capacity, 0.75f, true);
        this.capacity=capacity;
    }
    
    public int get(int key) {
        return cacheImpl.computeIfAbsent(key, value->{return -1;});
    }
    
    public void put(int key, int value) {
    
        cacheImpl.put(key, value);
        if(cacheImpl.size()>capacity)
            evictEntry();
    }

    public void evictEntry(){
        int eldestkey=cacheImpl.keySet().iterator().next();
        cacheImpl.remove(eldestkey);
    }
}

